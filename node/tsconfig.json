{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["main.ts", "lib/**/*.ts", "workers/**/*.ts"],
  "exclude": ["node_modules", "dist", ".history"]
}
